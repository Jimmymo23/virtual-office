generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  GUEST
}

enum UserStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  DONE
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Visibility {
  PRIVATE
  ASSIGNEES
  TEAM
  ROOM
  CUSTOM
  PUBLIC
}

enum VoiceMode {
  ALWAYS_ON
  PUSH_TO_TALK
  MUTED
}

enum ChannelType {
  ROOM
  DM
  THREAD
}

model User {
  id              String      @id @default(uuid())
  username        String      @unique
  passwordHash    String
  displayName     String
  role            Role        @default(STAFF)
  departmentId    String?
  avatarColor     String      @default("#EEEDFE")
  avatarTextColor String      @default("#534AB7")
  status          UserStatus  @default(OFFLINE)
  guestExpiresAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  department      Department?    @relation(fields: [departmentId], references: [id])
  attendanceLogs  AttendanceLog[]
  createdTasks    Task[]         @relation("TaskCreator")
  assignedTasks   TaskAssignee[]
  timeLogs        TimeLog[]
  sentMessages    Message[]
  promotedGuests  GuestPromotion[] @relation("PromotedBy")
  guestPromotion  GuestPromotion?  @relation("GuestUser")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model AttendanceLog {
  id           String    @id @default(uuid())
  userId       String
  clockIn      DateTime  @default(now())
  clockOut     DateTime?
  totalMinutes Int?
  date         DateTime  @default(now()) @db.Date
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])
}

model Room {
  id             String    @id @default(uuid())
  name           String
  voiceMode      VoiceMode @default(MUTED)
  hasVideo       Boolean   @default(false)
  capacity       Int       @default(10)
  isLockable     Boolean   @default(false)
  guestAccessible Boolean  @default(false)
  lockedById     String?
  templateId     String?
  zoneX          Int       @default(0)
  zoneY          Int       @default(0)
  zoneW          Int       @default(5)
  zoneH          Int       @default(5)
  color          String    @default("#E1F5EE")
  createdAt      DateTime  @default(now())

  tasks          Task[]
  messages       Message[]
  template       RoomTemplate? @relation(fields: [templateId], references: [id])
}

model RoomTemplate {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  voiceMode   VoiceMode @default(MUTED)
  hasVideo    Boolean   @default(false)
  capacity    Int       @default(10)
  isLockable  Boolean   @default(false)
  tileData    Json
  createdAt   DateTime  @default(now())

  rooms       Room[]
}

model MapTile {
  id          String   @id @default(uuid())
  x           Int
  y           Int
  layer       String
  tileType    String
  assetKey    String?
  roomId      String?
  mapVersion  Int      @default(1)

  @@unique([x, y, layer])
}

model Task {
  id           String       @id @default(uuid())
  parentTaskId String?
  title        String
  description  String?
  status       TaskStatus   @default(BACKLOG)
  priority     TaskPriority @default(MEDIUM)
  visibility   Visibility   @default(ASSIGNEES)
  creatorId    String
  roomId       String?
  dueDate      DateTime?
  estimateMin  Int?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  creator      User           @relation("TaskCreator", fields: [creatorId], references: [id])
  room         Room?          @relation(fields: [roomId], references: [id])
  parentTask   Task?          @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks     Task[]         @relation("SubTasks")
  assignees    TaskAssignee[]
  timeLogs     TimeLog[]
  customAccess TaskCustomAccess[]
  comments     Message[]      @relation("TaskComments")
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@id([taskId, userId])
}

model TaskCustomAccess {
  taskId String
  userId String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model TimeLog {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  minutes   Int?
  note      String?
  isManual  Boolean   @default(false)
  createdAt DateTime  @default(now())

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model Message {
  id          String      @id @default(uuid())
  senderId    String
  channelType ChannelType
  channelId   String
  parentMsgId String?
  roomId      String?
  taskId      String?
  body        String
  attachments Json?
  sentAt      DateTime    @default(now())
  editedAt    DateTime?

  sender      User        @relation(fields: [senderId], references: [id])
  room        Room?       @relation(fields: [roomId], references: [id])
  task        Task?       @relation("TaskComments", fields: [taskId], references: [id])
}

model GuestPromotion {
  id            String    @id @default(uuid())
  guestId       String    @unique
  promotedById  String
  roomAccess    String[]
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  guest         User      @relation("GuestUser", fields: [guestId], references: [id])
  promotedBy    User      @relation("PromotedBy", fields: [promotedById], references: [id])
}
